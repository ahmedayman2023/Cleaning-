rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users/{userId}/tasks
    // Document ID: taskId
    // Fields:
    //   - id: string (required)
    //   - title: string (required, max 100)
    //   - description: string (optional, max 1000)
    //   - category: string (required, enum: morning, evening, weekly)
    //   - completed: bool (required)
    //   - dayOfWeek: number (optional, 0-6)
    //   - userId: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Domain Validator
    function isValidTask(data) {
      return data.keys().hasAll(['id', 'title', 'category', 'completed', 'userId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 1000)) &&
             data.category in ['morning', 'evening', 'weekly'] &&
             data.completed is bool &&
             (!('dayOfWeek' in data) || (data.dayOfWeek is number && data.dayOfWeek >= 0 && data.dayOfWeek <= 6)) &&
             data.userId == request.auth.uid;
    }

    match /users/{userId}/tasks/{taskId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidTask(request.resource.data);
      allow update: if isOwner(userId) && isValidTask(request.resource.data) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(userId);
    }
  }
}
